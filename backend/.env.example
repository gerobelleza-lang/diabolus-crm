# Diabolus CRM — Backend Environment Variables
# Copia este archivo como .env y rellena los valores

# Supabase
SUPABASE_URL=https://emygbvxkhfbwyhbapaae.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firma electrónica
# 'mock' para desarrollo, 'firmaafy' para producción
SIGNATURE_PROVIDER=mock
FIRMAAFY_API_KEY=
FIRMAAFY_API_SECRET=

# URLs
FRONTEND_URL=https://gerobelleza-lang.github.io
BACKEND_URL=https://diabolus-crm.vercel.app

# OpenRouter (Semana 2: LLM Router L1-3)
# Haiku (€0.001), Sonnet (€0.005), GPT-4 (€0.02)
OPENROUTER_API_KEY=sk-or-...

# Stripe (Semana 2: Pagos, Suscripciones)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# WhatsApp Business (Semana 2: Recordatorios automáticos)
WHATSAPP_BUSINESS_ACCOUNT_ID=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_API_TOKEN=...

# Gmail Webhook (Semana 2: Auto-parse facturas proveedores)
GMAIL_SERVICE_ACCOUNT_EMAIL=...
GMAIL_PRIVATE_KEY=...

# Telegram (Semana 2: Alertas)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Otros
LOG_LEVEL=debug
NODE_ENV=development
