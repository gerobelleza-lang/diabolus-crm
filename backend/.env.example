# Diabolus CRM — Backend Environment Variables
# Copia este archivo como .env y rellena los valores

# Supabase
SUPABASE_URL=https://emygbvxkhfbwyhbapaae.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firma electrónica
# 'mock' para desarrollo, 'firmaafy' para producción
SIGNATURE_PROVIDER=mock
FIRMAAFY_API_KEY=
FIRMAAFY_API_SECRET=

# URLs
FRONTEND_URL=https://gerobelleza-lang.github.io
BACKEND_URL=https://diabolus-crm.vercel.app

# Otros
LOG_LEVEL=debug
NODE_ENV=development
